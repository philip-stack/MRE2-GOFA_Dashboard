EGM_ENABLE=0

# HMI login. Bitte fuer echten Betrieb aendern.
# SMAN_HMI_USERNAME=operator
# SMAN_HMI_PASSWORD=change-me
# SMAN_HMI_SESSION_SECRET=generate-a-long-random-secret
# SMAN_HMI_REQUIRE_HTTPS=1

# Optionaler lokaler HTTPS-Reverse-Proxy via Nginx.
# Start: docker compose --profile https up -d --build --force-recreate
# SMAN_HTTP_HOST=127.0.0.1
# SMAN_HTTP_PORT=8080
# SMAN_HTTPS_PORT=8443
# SMAN_SERVER_NAME=localhost
# SMAN_PUBLIC_HTTPS_URL=https://localhost:8443
# SMAN_TLS_CERT_FILE=sman-local.crt
# SMAN_TLS_KEY_FILE=sman-local.key

# Free/simple option: Gmail account with 2-Step Verification and an app password.
# SMAN_SMTP_HOST=smtp.gmail.com
# SMAN_SMTP_PORT=587
# SMAN_SMTP_SECURITY=starttls
# SMAN_SMTP_USER=your.name@gmail.com
# SMAN_SMTP_PASSWORD=your-16-character-app-password
# SMAN_MAIL_FROM=your.name@gmail.com
# SMAN_MAIL_RECIPIENTS=technik@example.com

# Free transactional option: Brevo SMTP relay account.
# SMAN_SMTP_HOST=smtp-relay.brevo.com
# SMAN_SMTP_PORT=587
# SMAN_SMTP_SECURITY=starttls
# SMAN_SMTP_USER=your-brevo-smtp-login
# SMAN_SMTP_PASSWORD=your-brevo-smtp-key
# SMAN_MAIL_FROM=verified-sender@example.com
# SMAN_MAIL_RECIPIENTS=technik@example.com
