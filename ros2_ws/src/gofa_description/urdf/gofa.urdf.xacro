<?xml version="1.0"?>
<robot name="gofa" xmlns:xacro="http://www.ros.org/wiki/xacro">
  <xacro:arg name="use_fake_hardware" default="true"/>

  <material name="abb_white">
    <color rgba="0.92 0.92 0.88 1.0"/>
  </material>
  <material name="abb_dark">
    <color rgba="0.16 0.17 0.18 1.0"/>
  </material>
  <material name="abb_red">
    <color rgba="1.0 0.05 0.04 1.0"/>
  </material>

  <xacro:macro name="mesh_link" params="name mesh color collision_radius collision_length">
    <link name="${name}">
      <visual>
        <geometry>
          <mesh filename="package://gofa_description/meshes/crb15000_5_95/visual/${mesh}"/>
        </geometry>
        <material name="${color}"/>
      </visual>
      <collision>
        <origin xyz="0 0 ${collision_length / 2}" rpy="0 0 0"/>
        <geometry>
          <cylinder radius="${collision_radius}" length="${collision_length}"/>
        </geometry>
      </collision>
      <inertial>
        <origin xyz="0 0 ${collision_length / 2}" rpy="0 0 0"/>
        <mass value="1.0"/>
        <inertia ixx="0.01" ixy="0" ixz="0" iyy="0.01" iyz="0" izz="0.01"/>
      </inertial>
    </link>
  </xacro:macro>

  <link name="world"/>

  <link name="base_link">
    <visual>
      <geometry>
        <mesh filename="package://gofa_description/meshes/crb15000_5_95/visual/base_link.stl"/>
      </geometry>
      <material name="abb_dark"/>
    </visual>
    <collision>
      <origin xyz="0 0 0.08" rpy="0 0 0"/>
      <geometry>
        <cylinder radius="0.18" length="0.16"/>
      </geometry>
    </collision>
    <inertial>
      <origin xyz="0 0 0.08" rpy="0 0 0"/>
      <mass value="5.0"/>
      <inertia ixx="0.05" ixy="0" ixz="0" iyy="0.05" iyz="0" izz="0.05"/>
    </inertial>
  </link>

  <joint name="world-base_link" type="fixed">
    <parent link="world"/>
    <child link="base_link"/>
  </joint>

  <xacro:mesh_link name="link_1" mesh="link_1.stl" color="abb_dark" collision_radius="0.115" collision_length="0.25"/>
  <xacro:mesh_link name="link_2" mesh="link_2.stl" color="abb_dark" collision_radius="0.095" collision_length="0.42"/>
  <xacro:mesh_link name="link_3" mesh="link_3.stl" color="abb_dark" collision_radius="0.085" collision_length="0.28"/>
  <xacro:mesh_link name="link_4" mesh="link_4.stl" color="abb_white" collision_radius="0.075" collision_length="0.34"/>
  <xacro:mesh_link name="link_5" mesh="link_5.stl" color="abb_white" collision_radius="0.065" collision_length="0.20"/>
  <xacro:mesh_link name="link_6" mesh="link_6.stl" color="abb_white" collision_radius="0.055" collision_length="0.14"/>

  <link name="flange"/>
  <link name="tool0"/>

  <joint type="revolute" name="joint_1">
    <origin xyz="0 0 0.265" rpy="0 0 0"/>
    <axis xyz="0 0 1"/>
    <parent link="base_link"/>
    <child link="link_1"/>
    <limit effort="80" lower="${radians(-180)}" upper="${radians(180)}" velocity="${radians(125)}"/>
  </joint>
  <joint type="revolute" name="joint_2">
    <origin xyz="0 0 0" rpy="0 0 0"/>
    <axis xyz="0 1 0"/>
    <parent link="link_1"/>
    <child link="link_2"/>
    <limit effort="80" lower="${radians(-180)}" upper="${radians(180)}" velocity="${radians(125)}"/>
  </joint>
  <joint type="revolute" name="joint_3">
    <origin xyz="0 0 0.444" rpy="0 0 0"/>
    <axis xyz="0 1 0"/>
    <parent link="link_2"/>
    <child link="link_3"/>
    <limit effort="80" lower="${radians(-225)}" upper="${radians(85)}" velocity="${radians(140)}"/>
  </joint>
  <joint type="revolute" name="joint_4">
    <origin xyz="0 0 0.110" rpy="0 0 0"/>
    <axis xyz="1 0 0"/>
    <parent link="link_3"/>
    <child link="link_4"/>
    <limit effort="40" lower="${radians(-180)}" upper="${radians(180)}" velocity="${radians(200)}"/>
  </joint>
  <joint type="revolute" name="joint_5">
    <origin xyz="0.470 0 0" rpy="0 0 0"/>
    <axis xyz="0 1 0"/>
    <parent link="link_4"/>
    <child link="link_5"/>
    <limit effort="40" lower="${radians(-180)}" upper="${radians(180)}" velocity="${radians(200)}"/>
  </joint>
  <joint type="revolute" name="joint_6">
    <origin xyz="0.101 0 0.080" rpy="0 0 0"/>
    <axis xyz="1 0 0"/>
    <parent link="link_5"/>
    <child link="link_6"/>
    <limit effort="20" lower="${radians(-180)}" upper="${radians(180)}" velocity="${radians(200)}"/>
  </joint>

  <joint type="fixed" name="joint_6-flange">
    <origin xyz="0 0 0" rpy="0 0 0"/>
    <parent link="link_6"/>
    <child link="flange"/>
  </joint>
  <joint name="flange-tool0" type="fixed">
    <origin xyz="0 0 0" rpy="0 ${radians(90)} 0"/>
    <parent link="flange"/>
    <child link="tool0"/>
  </joint>

  <ros2_control name="GoFaFakeSystem" type="system">
    <hardware>
      <plugin>mock_components/GenericSystem</plugin>
      <param name="calculate_dynamics">false</param>
    </hardware>
    <joint name="joint_1">
      <command_interface name="position"/>
      <state_interface name="position"><param name="initial_value">0.0</param></state_interface>
      <state_interface name="velocity"/>
    </joint>
    <joint name="joint_2">
      <command_interface name="position"/>
      <state_interface name="position"><param name="initial_value">0.0</param></state_interface>
      <state_interface name="velocity"/>
    </joint>
    <joint name="joint_3">
      <command_interface name="position"/>
      <state_interface name="position"><param name="initial_value">0.0</param></state_interface>
      <state_interface name="velocity"/>
    </joint>
    <joint name="joint_4">
      <command_interface name="position"/>
      <state_interface name="position"><param name="initial_value">0.0</param></state_interface>
      <state_interface name="velocity"/>
    </joint>
    <joint name="joint_5">
      <command_interface name="position"/>
      <state_interface name="position"><param name="initial_value">0.0</param></state_interface>
      <state_interface name="velocity"/>
    </joint>
    <joint name="joint_6">
      <command_interface name="position"/>
      <state_interface name="position"><param name="initial_value">0.0</param></state_interface>
      <state_interface name="velocity"/>
    </joint>
  </ros2_control>
</robot>
